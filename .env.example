# Gmail credentials for the Nodemailer SMTP transport
# Copy this file to .env and fill in your values.
# Never commit .env to Git.
NAME=
# Your Gmail address
EMAIL=your.gmail@gmail.com

# 16-character Gmail App Password
# Get it at: myaccount.google.com/apppasswords
# (2-Step Verification must be ON for App Passwords to work)
PASSWORD=xxxx xxxx xxxx xxxx

# The recipient email address where form submissions should be sent (e.g., sarahW@sarah.co)
# If not specified, defaults to work97464@gmail.com
TO_EMAIL=

